{
  "name": "engineerstech-mcp-server",
  "version": "1.0.0",
  "description": "Model Context Protocol (MCP) Server for engineersTech AI Sales Assistant - Deploy on ChatGPT, Tencent Cloud, Claude, and more",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest",
    "test:unit": "vitest run --reporter=verbose",
    "test:integration": "vitest run tests/integration --reporter=verbose",
    "test:chatgpt:integration": "node dist/tests/integration/chatgpt.test.js",
    "test:tencent:integration": "node dist/tests/integration/tencent.test.js",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "deploy:chatgpt": "npm run build && npm run test && node scripts/deploy-chatgpt.js",
    "deploy:tencent": "npm run build && npm run test && npm run serverless deploy",
    "docker:build": "docker build -t engineerstech-mcp:latest -f docker/Dockerfile .",
    "docker:run": "docker run -d -p 3000:3000 --env-file .env engineerstech-mcp:latest",
    "docker:push": "docker push engineerstech-mcp:latest"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "chatgpt",
    "tencent-cloud",
    "ai-sales-assistant",
    "openai",
    "claude"
  ],
  "author": "engineersTech",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "express": "^4.18.2",
    "axios": "^1.6.0",
    "dotenv": "^16.3.1",
    "winston": "^3.11.0",
    "redis": "^4.6.0",
    "zod": "^3.22.4",
    "cors": "^2.8.5"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "eslint": "^8.54.0",
    "prettier": "^3.1.0",
    "typescript": "^5.3.3",
    "tsx": "^4.6.2",
    "vitest": "^1.0.0",
    "@types/vitest": "^0.34.6"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
